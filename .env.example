# ATLAS Configuration Options
# Copy this file to .env and configure as needed.
# Only ATLAS_WORKSPACE_ROOT and the AI provider block below are required for
# a first project; everything else has a working default.

# Application Environment (development, testing, production)
ATLAS_ENVIRONMENT=development

# Logging Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
ATLAS_LOG_LEVEL=INFO

# Workspace Root Path -- where project directories are created
ATLAS_WORKSPACE_ROOT=./workspace

# -----------------------------------------------------------------------
# AI Provider
# -----------------------------------------------------------------------
# ATLAS talks to exactly one AI protocol at a time, selected by
# ATLAS_AI_PROTOCOL. Set it to one of: GEMINI, ANTHROPIC, OPENAI_COMPATIBLE,
# OLLAMA. Uncomment the matching block below and fill in its values; leave
# the other blocks commented out.

ATLAS_AI_PROTOCOL=GEMINI

# --- GEMINI (default provider) ------------------------------------------
# Google's Gemini API. Get a key at https://aistudio.google.com/apikey.
ATLAS_GEMINI_API_KEY=
ATLAS_GEMINI_MODEL=gemini-2.0-flash

# --- ANTHROPIC ------------------------------------------------------------
# Anthropic's Messages API (api.anthropic.com). Uncomment and set
# ATLAS_AI_PROTOCOL=ANTHROPIC above to use this instead of Gemini.
# ATLAS_AI_API_KEY=
# ATLAS_AI_MODEL=claude-sonnet-5
# ATLAS_AI_ENDPOINT is optional here -- defaults to
# https://api.anthropic.com/v1/messages.

# --- OPENAI_COMPATIBLE ------------------------------------------------------
# Any service implementing the OpenAI chat-completions API: OpenAI itself,
# or a locally-hosted OpenAI-compatible server such as LM Studio.
# ATLAS_AI_ENDPOINT and ATLAS_AI_MODEL are both required (there is no
# default endpoint for this protocol). Uncomment and set
# ATLAS_AI_PROTOCOL=OPENAI_COMPATIBLE above to use one of these.
#
# OpenAI:
# ATLAS_AI_ENDPOINT=https://api.openai.com/v1/chat/completions
# ATLAS_AI_MODEL=gpt-4o
# ATLAS_AI_API_KEY=
#
# LM Studio (local -- start the LM Studio local server first, then load a
# model in it; the endpoint below assumes LM Studio's default port):
# ATLAS_AI_ENDPOINT=http://localhost:1234/v1/chat/completions
# ATLAS_AI_MODEL=<the model name shown in LM Studio's server tab>
# ATLAS_AI_API_KEY is not required for LM Studio.

# --- OLLAMA (local) ---------------------------------------------------------
# Local models via Ollama (https://ollama.com). Install Ollama, run
# `ollama pull <model>`, then uncomment and set ATLAS_AI_PROTOCOL=OLLAMA.
# ATLAS_AI_MODEL=llama3.1
# ATLAS_AI_ENDPOINT is optional here -- defaults to http://localhost:11434.
# ATLAS_AI_API_KEY is not required for Ollama.

# --- Timeout ---------------------------------------------------------------
# HTTP request timeout, in seconds, applied to every AI protocol call.
# Cloud providers (Gemini, Anthropic, OpenAI) rarely need more than the
# default. Locally-hosted models (Ollama, LM Studio) generating long
# structured drafts on modest hardware can take well over a minute --
# raise this to 180-300 if you see AI provider timeout errors against a
# local model. Use `atlas presentation diagnostics` or the CLI's error
# output after a timeout to confirm which stage/provider is affected before
# raising this further.
ATLAS_AI_TIMEOUT_SECONDS=60
